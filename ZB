-- [[ ฟังก์ชันสร้างปุ่ม ]] --
local function MakeBtn(text, yPos, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = Main
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- 1. ระบบ Auto Click Green
_G.AutoG = false
local gBtn = MakeBtn("Auto Green: OFF", 40, Color3.fromRGB(60, 60, 60), function()
    _G.AutoG = not _G.AutoG
end)

task.spawn(function()
    while true do
        if _G.AutoG then
            gBtn.Text = "Auto Green: ON ✅"
            gBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") then
                    local name = v.Parent.Name:lower()
                    if name:find("green") or name:find("accept") or name:find("allow") then
                        fireclickdetector(v)
                    end
                end
            end
        else
            gBtn.Text = "Auto Green: OFF"
            gBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end
        task.wait(0.3)
    end
end)

-- 2. ระบบ ESP มองทะลุ
local espOn = false
MakeBtn("ESP (มองคน)", 80, Color3.fromRGB(100, 0, 200), function()
    espOn = not espOn
    if espOn then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= player and p.Character then
                local h = Instance.new("Highlight", p.Character)
                h.FillColor = Color3.fromRGB(255, 0, 0)
                h.Name = "DeltaESP"
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("DeltaESP") then
                p.Character.DeltaESP:Destroy()
            end
        end
    end
end)

